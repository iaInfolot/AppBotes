<?xml version="1.0" encoding="utf-8"?>
<!-- item_addon_row.xml
     Fila de premio adicional (addon) dentro de una tarjeta de juego.
     Ej: "El Millón — 1.000.000 €" en EuroMillones. -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="4dp">

    <!-- Bullet decorativo -->
    <View
        android:layout_width="6dp"
        android:layout_height="6dp"
        android:background="@drawable/bg_addon_bullet"
        android:layout_marginEnd="8dp" />

    <!-- Nombre del addon -->
    <TextView
        android:id="@+id/tvAddonName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text=""
        android:textColor="@color/text_secondary"
        android:textSize="16sp"
        android:fontFamily="sans-serif-light"
        android:maxLines="1"
        android:ellipsize="end" />

    <!-- Importe del addon -->
    <TextView
        android:id="@+id/tvAddonAmount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="@color/accent_gold_soft"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginStart="8dp" />

</LinearLayout>
