<?xml version="1.0" encoding="utf-8"?>
<!-- AndroidManifest.xml -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ================================================
         PERMISOS NECESARIOS
         ================================================ -->
    <!-- Acceso a internet para obtener datos del webservice -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Arranque automático al encender el dispositivo -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Mantener CPU activa durante el refresco de datos -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Declarar que es una app de TV (requerido para Android TV) -->
    <uses-feature
        android:name="android.hardware.touchscreen"
        android:required="false" />
    <uses-feature
        android:name="android.software.leanback"
        android:required="true" />

    <application
        android:name=".SelaeApplication"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/Theme.SelaeSignage"
        android:usesCleartextTraffic="true"
        android:networkSecurityConfig="@xml/network_security_config">

        <!-- ================================================
             ACTIVIDAD PRINCIPAL — pantalla de señalización
             ================================================ -->
        <activity
            android:name=".ui.MainActivity"
            android:configChanges="keyboard|keyboardHidden|navigation|orientation|screenLayout|screenSize|smallestScreenSize"
            android:exported="true"
            android:immersive="true"
            android:launchMode="singleInstance"
            android:screenOrientation="landscape">

            <!-- Intent filter para launcher de TV -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>

            <!-- Intent filter estándar por si también se instala en no-TV -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ================================================
             RECEIVER DE ARRANQUE AUTOMÁTICO
             ================================================ -->
        <receiver
            android:name=".receiver.BootReceiver"
            android:exported="true"
            android:enabled="true">
            <intent-filter android:priority="1000">
                <!-- Se lanza al arrancar el sistema -->
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <!-- Algunos fabricantes usan este intent adicional -->
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
