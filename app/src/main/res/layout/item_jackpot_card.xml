<?xml version="1.0" encoding="utf-8"?>
<!-- item_jackpot_card.xml
     Tarjeta individual de un juego/bote de SELAE.
     Diseño vertical con logo, nombre, bote y fecha del sorteo. -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_margin="@dimen/card_margin"
    app:cardBackgroundColor="@color/card_bg"
    app:cardCornerRadius="@dimen/card_corner_radius"
    app:cardElevation="12dp">

    <!-- Degradado interno de la tarjeta -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bg_card_gradient"
        android:padding="@dimen/card_padding">

        <!-- ──── LOGO DEL JUEGO ──── -->
        <ImageView
            android:id="@+id/imgGameLogo"
            android:layout_width="@dimen/logo_size"
            android:layout_height="@dimen/logo_size"
            android:scaleType="fitCenter"
            android:contentDescription="@string/game_logo_desc"
            android:layout_marginBottom="12dp" />

        <!-- ──── NOMBRE DEL JUEGO ──── -->
        <TextView
            android:id="@+id/tvGameName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_game_name"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:maxLines="2"
            android:ellipsize="end"
            android:letterSpacing="0.03"
            android:layout_marginBottom="16dp" />

        <!-- ──── SEPARADOR DECORATIVO ──── -->
        <View
            android:layout_width="60dp"
            android:layout_height="3dp"
            android:background="@drawable/divider_accent"
            android:layout_marginBottom="16dp" />

        <!-- ──── IMPORTE DEL BOTE ────
             autoSizeTextType usa namespace app: para compatibilidad API 23+
             paddingHorizontal/Vertical reemplazados por start/end/top/bottom -->
        <TextView
            android:id="@+id/tvJackpotAmount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0 €"
            android:textColor="@color/accent_gold"
            android:textSize="@dimen/text_jackpot"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black"
            android:gravity="center"
            android:maxLines="1"
            android:letterSpacing="-0.02"
            android:layout_marginBottom="10dp"
            app:autoSizeTextType="uniform"
            app:autoSizeMinTextSize="20sp"
            app:autoSizeMaxTextSize="@dimen/text_jackpot" />

        <!-- ──── FECHA DEL SORTEO ──── -->
        <TextView
            android:id="@+id/tvDrawDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_draw_date"
            android:fontFamily="sans-serif-light"
            android:gravity="center"
            android:maxLines="1"
            android:drawablePadding="6dp"
            android:drawableStart="@drawable/ic_calendar"
            android:layout_marginBottom="12dp" />

        <!-- ──── ADDONS (premios adicionales) ────
             paddingHorizontal/Vertical reemplazados por start/end/top/bottom -->
        <LinearLayout
            android:id="@+id/containerAddons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:background="@drawable/bg_addon_container"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:layout_marginTop="6dp" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
